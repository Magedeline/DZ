{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "E:/Celeste Desolo Zantas/Celeste.exe",
			"args": [
				"build",
				"MaggyHelper.sln"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "E:/Celeste Desolo Zantas/Celeste.exe",
			"args": [
				"watch",
				"--project",
				"MaggyHelper.sln",
				"build"
			],
			"isBackground": true,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
